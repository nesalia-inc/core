{
  "name": "@deessejs/core",
  "version": "0.5.0",
  "description": "Type-safe error handling for TypeScript - Result, Maybe, Try, and AsyncResult monads with zero runtime dependencies",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./public/*": "./public/*"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.2"
  },
  "keywords": [
    "typescript",
    "functional-programming",
    "result",
    "maybe",
    "try",
    "error-handling",
    "monad",
    "async",
    " Either",
    "option"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/nesalia-inc/core.git",
    "directory": "packages/core"
  },
  "homepage": "https://core.nesalia.com",
  "bugs": {
    "url": "https://github.com/nesalia-inc/core/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/nesalia-inc"
  },
  "license": "MIT",
  "dependencies": {
    "zod": "^4.0.0"
  }
}
